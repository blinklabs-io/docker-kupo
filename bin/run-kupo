#!/usr/bin/env bash

[[ -n ${DEBUG:-} ]] && set -x

set -euo pipefail

has_option() {
	local opt=${1}
	shift
	local arg
	for arg in "${@}"; do
		case "${arg}" in
			"${opt}"|"${opt}"=*) return 0 ;;
		esac
	done
	return 1
}

is_true() {
	case "${1:-}" in
		true|TRUE|True|1|yes|YES|Yes) return 0 ;;
		*) return 1 ;;
	esac
}

has_chain_producer() {
	has_option --node-socket "${@}" ||
		has_option --node-config "${@}" ||
		has_option --ogmios-host "${@}" ||
		has_option --ogmios-port "${@}" ||
		has_option --hydra-host "${@}" ||
		has_option --hydra-port "${@}" ||
		has_option --read-only "${@}"
}

has_database_location() {
	has_option --workdir "${@}" ||
		has_option --in-memory "${@}"
}

options=()

KUPO_NETWORK=${KUPO_NETWORK:-${CARDANO_NETWORK:-${NETWORK:-mainnet}}}
CARDANO_CONFIG_BASE=${CARDANO_CONFIG_BASE:-/opt/cardano/config}

if ! has_chain_producer "${@}"; then
	KUPO_CHAIN_PRODUCER=${KUPO_CHAIN_PRODUCER:-node}
	case "${KUPO_CHAIN_PRODUCER}" in
		node|cardano-node)
			KUPO_NODE_SOCKET=${KUPO_NODE_SOCKET:-${CARDANO_NODE_SOCKET_PATH:-/ipc/node.socket}}
			KUPO_NODE_CONFIG=${KUPO_NODE_CONFIG:-${CARDANO_NODE_CONFIG:-${CARDANO_CONFIG_BASE}/${KUPO_NETWORK}/config.json}}
			options+=(--node-socket "${KUPO_NODE_SOCKET}")
			options+=(--node-config "${KUPO_NODE_CONFIG}")
			;;
		ogmios)
			: "${KUPO_OGMIOS_HOST:?KUPO_OGMIOS_HOST is required when KUPO_CHAIN_PRODUCER=ogmios}"
			: "${KUPO_OGMIOS_PORT:?KUPO_OGMIOS_PORT is required when KUPO_CHAIN_PRODUCER=ogmios}"
			options+=(--ogmios-host "${KUPO_OGMIOS_HOST}")
			options+=(--ogmios-port "${KUPO_OGMIOS_PORT}")
			;;
		hydra)
			: "${KUPO_HYDRA_HOST:?KUPO_HYDRA_HOST is required when KUPO_CHAIN_PRODUCER=hydra}"
			: "${KUPO_HYDRA_PORT:?KUPO_HYDRA_PORT is required when KUPO_CHAIN_PRODUCER=hydra}"
			options+=(--hydra-host "${KUPO_HYDRA_HOST}")
			options+=(--hydra-port "${KUPO_HYDRA_PORT}")
			;;
		read-only|readonly)
			options+=(--read-only)
			;;
		*)
			echo "Unsupported KUPO_CHAIN_PRODUCER=${KUPO_CHAIN_PRODUCER}. Use node, ogmios, hydra, or read-only." >&2
			exit 1
			;;
	esac
fi

if ! has_database_location "${@}"; then
	if is_true "${KUPO_IN_MEMORY:-false}"; then
		options+=(--in-memory)
	else
		KUPO_WORKDIR=${KUPO_WORKDIR:-/data}
		mkdir -p "${KUPO_WORKDIR}"
		options+=(--workdir "${KUPO_WORKDIR}")
	fi
fi

if ! has_option --host "${@}"; then
	options+=(--host "${KUPO_HOST:-0.0.0.0}")
fi

if ! has_option --port "${@}"; then
	options+=(--port "${KUPO_PORT:-1442}")
fi

if [[ -n ${KUPO_SINCE:-} ]] && ! has_option --since "${@}"; then
	options+=(--since "${KUPO_SINCE}")
fi

if [[ -n ${KUPO_UNTIL:-} ]] && ! has_option --until "${@}"; then
	options+=(--until "${KUPO_UNTIL}")
fi

if [[ -n ${KUPO_MATCH:-${KUPO_MATCHES:-}} ]] && ! has_option --match "${@}"; then
	IFS=',' read -r -a matches <<< "${KUPO_MATCH:-${KUPO_MATCHES:-}}"
	for match in "${matches[@]}"; do
		[[ -n ${match} ]] && options+=(--match "${match}")
	done
fi

if is_true "${KUPO_PRUNE_UTXO:-false}" && ! has_option --prune-utxo "${@}"; then
	options+=(--prune-utxo)
fi

if is_true "${KUPO_DEFER_DB_INDEXES:-false}" && ! has_option --defer-db-indexes "${@}"; then
	options+=(--defer-db-indexes)
fi

if [[ -n ${KUPO_GC_INTERVAL:-} ]] && ! has_option --gc-interval "${@}"; then
	options+=(--gc-interval "${KUPO_GC_INTERVAL}")
fi

if [[ -n ${KUPO_LOG_LEVEL:-} ]] && ! has_option --log-level "${@}"; then
	options+=(--log-level "${KUPO_LOG_LEVEL}")
fi

echo kupo "${options[@]}" "${@}"
exec /usr/local/bin/kupo "${options[@]}" "${@}"
